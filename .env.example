# Copy this file to `.env` and fill in real values.
# `.env` is gitignored — never commit real credentials.

# Mode Analytics — API credentials (https://app.mode.com → My Account → API Tokens)
MODE_TOKEN=
MODE_SECRET=

# Groq — LLM API key (https://console.groq.com)
GROQ_API_KEY=

# Slack — Incoming webhook URL (https://api.slack.com/apps)
SLACK_WEBHOOK_URL=
